# Django environment variables
# Copy this file to .env and fill in your values

# Docker: match container user to host (id -u / id -g)
UID=1000
GID=1000
# Set to 1 to skip "poetry install" on container start (faster restarts)
# SKIP_POETRY_INSTALL=0

# Security settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True  # Set to False in production

# Database settings
# Add database settings if needed

# Email settings
# Add email settings if needed
