# Django environment variables
# Copy this file to .env and fill in your values

# Docker: match container user to host (id -u / id -g)
UID=1000
GID=1000
# Set to 1 to skip "poetry install" on container start (faster restarts)
# SKIP_POETRY_INSTALL=0

# Security settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True  # Set to False in production
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Google OAuth — preencher antes de testar login Google
# Enquanto o app estiver em Testing no Google Cloud, adicione seu email em Test users
#
# Google Cloud Console → Credentials → OAuth 2.0 Web client:
#   Authorized JavaScript origins:
#     http://localhost:8000
#     https://SEU-DOMINIO.com
#   Authorized redirect URIs (fluxo OAuth — obrigatório):
#     http://localhost:8000/accounts/google/login/callback/
#     https://SEU-DOMINIO.com/accounts/google/login/callback/
#   NÃO use /accounts/google/login/ como redirect URI
#   O botão GIS envia POST para /accounts/google/login/token/ (não cadastrar como redirect)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-client-secret

# Domínio do Site framework (dev: localhost:8000; produção: seudominio.com)
DJANGO_SITE_DOMAIN=localhost:8000

# Database settings
# Add database settings if needed

# Email settings
# Add email settings if needed
